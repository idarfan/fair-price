  "containerHTML": " <div class=\"small-12 column\"> <!-- ngIf: !hideSymbol --> <div class=\"form-group\"> <bc-checkbox-dropdown cb-label=\"'Options Type'\" cb-id=\"'bc-symbol-type-param'\" cb-list=\"symbolTypeList\" cb-model=\"params.symbolType\"><div>\n    <label class=\"form-label bc-dropdown-list-link\" data-dropdown-toggle=\"#bc-symbol-type-param\" data-bc-dropdown-fix=\"\" data-bc-accessibility=\"\" data-type=\"'link'\" data-ng-class=\"{'disabled': cbDisabled}\" tabindex=\"0\" role=\"link\">\n        Options Type\n        <i class=\"bc-glyph-sort-desc close\"></i>\n        <i class=\"bc-glyph-sort-asc open\"></i>\n    </label>\n    <div id=\"bc-symbol-type-param\" class=\"f-dropdown bc-dropdown-list-wrapper bc-dropdown-fix  \">\n        <ul class=\"bc-dropdown-list\">\n            <!-- ngRepeat: item in cbList --><li data-ng-repeat=\"item in cbList\">\n                <div class=\"input-checkbox\">\n                    <input id=\"bc-symbol-type-param-Call\" data-checklist-value=\"item\" data-ng-disabled=\"cbDisabled\" data-ng-click=\"checkAll(item)\" type=\"checkbox\" ng-model=\"checked\" class=\"ng-pristine ng-untouched ng-valid\" data-checklist-model=\"cbModel\" style=\"\">\n\n                    <label class=\"checkbox clearfix\" for=\"bc-symbol-type-param-Call\" data-bc-accessibility=\"\" data-checkbox-checked=\"cbModel.indexOf(item) !== -1\" tabindex=\"0\" role=\"checkbox\" aria-checked=\"true\">\n                        <span class=\"bc-glyph-check\"></span>\n                        <span class=\"name\" data-ng-bind-html=\"cbListNames[item] || item\">Call</span>\n                    </label>\n                </div>\n\n            </li><!-- end ngRepeat: item in cbList --><li data-ng-repeat=\"item in cbList\">\n                <div class=\"input-checkbox\">\n                    <input id=\"bc-symbol-type-param-Put\" data-checklist-value=\"item\" data-ng-disabled=\"cbDisabled\" data-ng-click=\"checkAll(item)\" type=\"checkbox\" ng-model=\"checked\" class=\"ng-pristine ng-untouched ng-valid\" data-checklist-model=\"cbModel\" style=\"\">\n\n                    <label class=\"checkbox clearfix\" for=\"",
