# 敏感檔案（絕對不能推上公開 repo）
.env*
config/master.key
config/credentials/*.key

# Rails
/log/*
/tmp/*
/storage/*
/public/assets
/public/packs

# SQLite
/db/*.sqlite3
/db/*.sqlite3-*

# Bundler
/vendor/bundle

# Windows WSL2 Zone.Identifier
*:Zone.Identifier

# OS / 編輯器
.DS_Store
*.swp
.vscode/
.idea/

# Node
/node_modules

# Claude Code 本地設定
.claude/settings.local.json

# 測試覆蓋率報告
/coverage/

# docs 截圖與 PDF（不追蹤二進制媒體）
docs/*.png
docs/*.jpg
docs/*.pdf

# Vite Ruby
/public/vite*
node_modules
# Vite uses dotenv and suggests to ignore local-only env files. See
# https://vitejs.dev/guide/env-and-mode.html#env-files
*.local

